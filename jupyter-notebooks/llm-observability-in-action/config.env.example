# Copy this file to config.env and edit for your environment.

# Namespace that hosts your llm-observability-stack release.
K8S_NAMESPACE=llm-observability

# Optional. Keep empty to use kubectl current-context.
K8S_CONTEXT=

# Helm release name used by your stack.
K8S_RELEASE=llm-observability-stack

# Expected service/deployment names used by checks.
OPENWEBUI_SERVICE=open-webui
OLLAMA_SERVICE=ollama
LANGCHAIN_SERVICE=langchain-demo
PYTHON_TOOLBOX_DEPLOYMENT=python-toolbox

# 0 = read-only mode (default), 1 = allow mutating kubectl verbs.
APPLY_CHANGES=0
