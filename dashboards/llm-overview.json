    {"type": "stat", "title": "Error rate", "id": 2, "gridPos": {"h": 8, "w": 6, "x": 6, "y": 0}, "fieldConfig": {"defaults": {"unit": "percentunit"}}, "targets": [{"expr": "sum(rate(llm_observability_llm_requests_total{outcome=\"error\"}[5m])) / clamp_min(sum(rate(llm_observability_llm_requests_total[5m])), 0.001)", "refId": "A"}]},
    {"type": "stat", "title": "Active LLM requests", "id": 3, "gridPos": {"h": 8, "w": 6, "x": 12, "y": 0}, "targets": [{"expr": "sum(llm_observability_llm_active_requests)", "refId": "A"}]},
